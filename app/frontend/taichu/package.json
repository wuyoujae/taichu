    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "concurrently": "^9",
    "electron": "^33.0.0",
    "typescript": "^5",
    "vite": "^6",
    "wait-on": "^8"
  }
}
