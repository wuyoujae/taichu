BACKEND_HOST=127.0.0.1
BACKEND_PORT=4000
BACKEND_DATA_DIR=./data

YUANLING_ENABLED=true
YUANLING_AI_ENABLED=true
# 可选值：openai-compatible | anthropic-compatible
YUANLING_AI_PROVIDER=openai-compatible
# 可选，默认按供应商自动映射（兼容常规：openai-base 或 anthropic-base）
YUANLING_AI_ENDPOINT=https://api.openai.com/v1
# 供应商专用别名（优先级更高）
YUANLING_OPENAI_BASE_URL=
YUANLING_ANTHROPIC_BASE_URL=
# 可选，默认按供应商自动映射：/chat/completions 或 /v1/messages
YUANLING_AI_REQUEST_PATH=/chat/completions
# 用于鉴权的 key（不提交到仓库）
YUANLING_AI_API_KEY=
# 供应商专用 Key（优先级更高）
YUANLING_OPENAI_API_KEY=
YUANLING_ANTHROPIC_API_KEY=
# 可选，模型名
YUANLING_AI_MODEL=gpt-4o-mini
YUANLING_AI_PROMPT_TEMPLATE=You are YUANLING, a practical assistant.
YUANLING_AI_TOP_P=0.95
YUANLING_AI_TEMPERATURE=0.7
YUANLING_AI_TIMEOUT_MS=60000
# 覆盖鉴权头名，Anthropic 常用 x-api-key
YUANLING_AI_AUTH_HEADER=Authorization

# Context（会话级上下文）配置
YUANLING_CONTEXT_ENABLED=true
YUANLING_CONTEXT_SESSION_ENABLED=true
# 会话级上下文保留策略：tail_turns（按会话轮次）或 tail_tokens（按 token）
YUANLING_CONTEXT_RETENTION_MODE=tail_turns
YUANLING_CONTEXT_MAX_TURNS=20
YUANLING_CONTEXT_MAX_TOKENS=12000
YUANLING_CONTEXT_KEEP_SYSTEM_PROMPT=true
YUANLING_CONTEXT_SESSION_TTL_MINUTES=30
YUANLING_CONTEXT_STORAGE_DIR=
YUANLING_CONTEXT_AUTO_COMPACT_ENABLED=true
YUANLING_CONTEXT_COMPACT_THRESHOLD_TOKENS=12000
YUANLING_CONTEXT_PRESERVE_RECENT_MESSAGES=4
YUANLING_CONTEXT_AI_COMPACT_ENABLED=true
YUANLING_CONTEXT_COMPACT_MAX_OUTPUT_TOKENS=1200
YUANLING_CONTEXT_COMPACT_SYSTEM_PROMPT=Summarize the earlier session context for a continuing AI agent. Preserve decisions, user intent, open tasks, tool results, files, constraints, and anything needed to resume without asking the user to repeat themselves. Return only the summary.
YUANLING_CONTEXT_INPUT_TOKEN_PRICE_PER_1M=0
YUANLING_CONTEXT_OUTPUT_TOKEN_PRICE_PER_1M=0
YUANLING_CONTEXT_ROTATE_AFTER_BYTES=262144
YUANLING_CONTEXT_MAX_ROTATED_FILES=3
YUANLING_CONTEXT_EXPIRE_ACTION=archive

YUANLING_MEMORY_STRATEGY=window
YUANLING_MEMORY_MAX_TURNS=20
