BACKEND_HOST=127.0.0.1
BACKEND_PORT=4000
BACKEND_DATA_DIR=./data

YUANLING_ENABLED=true
YUANLING_AI_ENABLED=true
# 可选值：openai-compatible | anthropic-compatible
YUANLING_AI_PROVIDER=openai-compatible
# 可选，默认按供应商自动映射（兼容常规：openai-base 或 anthropic-base）
YUANLING_AI_ENDPOINT=https://api.openai.com/v1
# 供应商专用别名（优先级更高）
YUANLING_OPENAI_BASE_URL=
YUANLING_ANTHROPIC_BASE_URL=
# 可选，默认按供应商自动映射：/chat/completions 或 /v1/messages
YUANLING_AI_REQUEST_PATH=/chat/completions
# 用于鉴权的 key（不提交到仓库）
YUANLING_AI_API_KEY=
# 供应商专用 Key（优先级更高）
YUANLING_OPENAI_API_KEY=
YUANLING_ANTHROPIC_API_KEY=
# 可选，模型名
YUANLING_AI_MODEL=gpt-4o-mini
YUANLING_AI_PROMPT_TEMPLATE=You are YUANLING, a practical assistant.
YUANLING_AI_TOP_P=0.95
YUANLING_AI_TEMPERATURE=0.7
YUANLING_AI_TIMEOUT_MS=60000
# 覆盖鉴权头名，Anthropic 常用 x-api-key
YUANLING_AI_AUTH_HEADER=Authorization

# Contact（元灵内部通信）配置
YUANLING_CONTACT_ENABLED=true
YUANLING_CONTACT_STORAGE_DIR=

# Agent（消息驱动循环）配置
YUANLING_AGENT_ENABLED=true
YUANLING_AGENT_DEFAULT_USER_ID=000000
YUANLING_AGENT_DEFAULT_ENTRY_ID=000001
YUANLING_AGENT_USER_IDS=000000
YUANLING_AGENT_STREAMING_ENABLED=true
# 0 表示默认直到 AI 不再调用工具；大于 0 时作为硬上限
YUANLING_AGENT_MAX_TOOL_ITERATIONS=0
YUANLING_AGENT_MAX_OUTPUT_TOKENS=4096

# Context（元灵长期上下文）配置
YUANLING_CONTEXT_ENABLED=true
YUANLING_CONTEXT_STATE_ENABLED=true
# 元灵长期上下文保留策略：tail_turns（按最近轮次）或 tail_tokens（按 token）
YUANLING_CONTEXT_RETENTION_MODE=tail_turns
YUANLING_CONTEXT_MAX_TURNS=20
YUANLING_CONTEXT_MAX_TOKENS=12000
YUANLING_CONTEXT_KEEP_SYSTEM_PROMPT=true
YUANLING_CONTEXT_TTL_MINUTES=30
YUANLING_CONTEXT_STORAGE_DIR=
YUANLING_CONTEXT_AUTO_COMPACT_ENABLED=true
YUANLING_CONTEXT_COMPACT_THRESHOLD_TOKENS=12000
YUANLING_CONTEXT_PRESERVE_RECENT_MESSAGES=4
YUANLING_CONTEXT_AI_COMPACT_ENABLED=true
YUANLING_CONTEXT_COMPACT_MAX_OUTPUT_TOKENS=1200
YUANLING_CONTEXT_COMPACT_SYSTEM_PROMPT=Summarize the earlier yuanling context for a continuing AI agent. Preserve decisions, user intent, open tasks, tool results, files, constraints, and anything needed to resume without asking the user to repeat themselves. Return only the summary.
YUANLING_CONTEXT_INPUT_TOKEN_PRICE_PER_1M=0
YUANLING_CONTEXT_OUTPUT_TOKEN_PRICE_PER_1M=0
YUANLING_CONTEXT_ROTATE_AFTER_BYTES=262144
YUANLING_CONTEXT_MAX_ROTATED_FILES=3
YUANLING_CONTEXT_EXPIRE_ACTION=archive

# Tools（工具注册与发现）配置
YUANLING_TOOLS_ENABLED=true
# 为空表示允许全部已注册工具；支持逗号或空格分隔，也支持 read/write/edit/glob/grep 别名
YUANLING_TOOLS_ALLOWED=
YUANLING_TOOLS_MAX_SEARCH_RESULTS=10
# global 表示工具可按用户权限访问全局文件系统；workspace 表示限制在 YUANLING_TOOLS_WORKSPACE_ROOT 内
YUANLING_TOOLS_FILESYSTEM_SCOPE=global
YUANLING_TOOLS_WORKSPACE_ROOT=
YUANLING_TOOLS_STATE_DIR=
YUANLING_TOOLS_AUTO_ALLOW_READ=true
YUANLING_TOOLS_CONFIRM_WORKSPACE_WRITE=true
YUANLING_TOOLS_CONFIRM_DANGER_FULL_ACCESS=true

# Skills（技能注册、发现与注入）配置
YUANLING_SKILLS_ENABLED=true
# 默认会加载 {BACKEND_DATA_DIR}/yuanling/skills；这里可额外配置显式 skills roots
YUANLING_SKILLS_ROOTS=
YUANLING_SKILLS_ALLOWED=
YUANLING_SKILLS_INCLUDE_USER_HOME=true
YUANLING_SKILLS_MAX_PROMPT_CHARS=40000
YUANLING_SKILLS_MAX_SEARCH_RESULTS=10
YUANLING_SKILLS_AUTO_INJECT_ENABLED=true
YUANLING_SKILLS_AUTO_INJECT_MAX_ITEMS=20

YUANLING_MEMORY_STRATEGY=window
YUANLING_MEMORY_MAX_TURNS=20

# Spiritkind（元族/子智能体注册中心）配置
SPIRITKIND_ENABLED=true
SPIRITKIND_STORAGE_DIR=

# MCP (Model Context Protocol) 配置
YUANLING_MCP_ENABLED=true
# JSON object: {"serverName":{"type":"stdio","command":"python3","args":["server.py"],"env":{},"tool_call_timeout_ms":30000}}
YUANLING_MCP_SERVERS_JSON=
YUANLING_MCP_INITIALIZE_TIMEOUT_MS=10000
YUANLING_MCP_LIST_TOOLS_TIMEOUT_MS=30000
YUANLING_MCP_TOOL_CALL_TIMEOUT_MS=30000
YUANLING_MCP_RESOURCE_TIMEOUT_MS=30000
